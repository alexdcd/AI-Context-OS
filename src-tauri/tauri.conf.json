{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AI Context OS",
  "version": "0.1.0",
  "identifier": "com.mafialabs.aicontextos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Context OS",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown text file",
        "mimeType": "text/markdown",
        "role": "Editor"
      },
      {
        "ext": ["txt"],
        "name": "Plain Text",
        "description": "Plain text file",
        "mimeType": "text/plain",
        "role": "Editor"
      },
      {
        "ext": ["json"],
        "name": "JSON Document",
        "description": "JSON data file",
        "mimeType": "application/json",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFMEIwMEMwMzExRjAxMTcKUldRWEFSOHh3QUFMbmpWMCttcnF1SlB3SWF1L3hlNmw3OUJDZVhPa2llenpUTUowaUplWVJRMXAK",
      "endpoints": [
        "https://github.com/alexdcd/AI-Context-OS/releases/latest/download/latest.json"
      ]
    }
  }
}
